  "metadata": {
    "version": "1.0",
    "created": "2025-11-25",
    "description": "Station configuration for Ruihang CCL production line",
    "fields": {
      "number": "Unique station identifier (int)",
      "tank": "Physical tank number - tank can contain multiple stations, tank number = lowest station number in the tank (int)",
      "group": "Process group number - stations with same group are interchangeable (int)",
      "name": "Station name/type (string)",
      "x_position": "Physical position in mm along the line (int) - extracted from layout drawing",
      "y_position": "Physical position in mm perpendicular to line (int) - extracted from layout drawing",
      "z_position": "Physical position in mm vertical height (int) - placeholder set to 0",
      "dropping_time": "Time in seconds to drop/lift parts at this station (int)",
      "operation": "0 = dry station (buffer/dryer), 1 = wet station (treatment tank) (int)",
      "device_delay": "Additional device-specific delay in seconds (float)"
    },
    "relationships": {
      "tank_to_station": "1:n (one tank can contain multiple stations)",
      "station_to_tank": "n:1 (each station belongs to exactly one tank)",
      "tank_numbering": "Tank number = lowest station number within that tank",
      "group_numbering": "Group number = lowest station number in the interchangeable group"
    },
    "notes": [
      "Stations extracted from treatment program specifications for SPM 70-21-XX products",
      "100-series stations: process line stations (main line, Y=0mm)",
      "200-series stations: special treatment stations (parallel line, Y=3300mm)",
      "X and Y coordinates extracted from plant layout drawing dated 2025-11-25",
      "Position coordinates in millimeters: x = along line, y = perpendicular, z = vertical",
      "100-series Y-position: 0mm (main process line)",
      "200-series Y-position: 3300mm (parallel line, constant distance from main line)",
      "Z-position remains 0 (placeholder for vertical height)"
    ]
  }
}
