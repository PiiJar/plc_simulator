  "metadata": {
    "version": "1.0",
    "created": "2025-12-04",
    "description": "Station configuration for Ouneva production line",
    "fields": {
      "number": "Unique station identifier (int)",
      "tank": "Physical tank number - tank can contain multiple stations, tank number = lowest station number in the tank (int)",
      "group": "Process group number - stations with same group are interchangeable (int)",
      "name": "Station name/type (string)",
      "x_position": "Physical position in mm along the line (int) - initial layout 500mm start, 1000mm intervals",
      "y_position": "Physical position in mm perpendicular to line (int) - set to 0",
      "z_position": "Physical position in mm vertical height (int) - placeholder set to 0",
      "dropping_time": "Time in seconds to drop/lift parts at this station (int)",
      "device_delay": "Additional device-specific delay in seconds (float)",
      "operation": "0 = dry normal, 1 = wet normal, 10 = dry cross-transfer, 11 = wet cross-transfer (int)"
    },
    "groups": {
      "303": "Varasto / Poikittaiskuljetin - stations 303, 304 (type 10 cross-transfer)",
      "325": "Huuhtelu/Poikittaiskuljetin - stations 325, 425 (type 11 cross-transfer between lines)",
      "403": "Purkaus / Poikittaiskuljetin - stations 403, 404 (type 10 cross-transfer)",
      "410": "Tina - stations 410, 411, 412",
      "420": "Alkalinen kupari - stations 420, 421, 422",
      "note": "All Huuhtelu (rinse) stations are individual groups - NOT parallel"
    },
    "cross_transfers": {
      "303_304": {
        "stations": [
          303,
          304
        ],
        "operation": 10,
        "description": "Dry cross-transfer within 300-line"
      },
      "325_425": {
        "stations": [
          325,
          425
        ],
        "operation": 11,
        "description": "Wet cross-transfer between 300-line and 400-line",
        "group": 325
      },
      "403_404": {
        "stations": [
          403,
          404
        ],
        "operation": 10,
        "description": "Dry cross-transfer within 400-line"
      }
    },
    "notes": [
      "Stations extracted from Ouneva process layout image",
      "300-series stations: main process line (Y=1350mm)",
      "400-series stations: secondary process line (Y=5790mm)",
      "X-positions: provisional layout starting from 500mm with 1000mm intervals",
      "Station 301 designated as start station (Lastaus/Loading)",
      "Group numbers set to smallest station number in each group",
      "CROSS-TRANSFERS: Stations with type 10/11 are cross-transfer points",
      "  - Type 10: Dry cross-transfer (no liquid dripping)",
      "  - Type 11: Wet cross-transfer (liquid dripping, slower movement)",
      "  - Cross-transfer stations in same group (e.g., 325 & 425 in group 325)",
      "  - Treatment program lists one station per stage, CP-SAT selects correct station based on transporter",
      "  - Example: Stage 15 (325) → 300-line transporter uses 325, Stage 16 (415-424) → 400-line transporter uses 425 from group 325",
      "IMPLEMENTATION: No code changes needed - current model handles cross-transfers via station groups"
    ]
  }
}
