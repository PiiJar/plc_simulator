(* MultiValvePumpType - Data structure derived from param.multi_valve_pump SQL tables *)
(* Generic recipe-based valve+pump controller configuration *)
(* Supports up to 8 valves with individual feedback settings and 1 pump *)
TYPE UDT_MultiValvePumpType :
STRUCT
    Id : INT; (* Primary key *)
    IsInUse : BOOL; (* Control enabled *)
    AllowPumpZeroValves : BOOL; (* TRUE=allow pumping when recipe has all valves closed, e.g. transfer tank emptying *)
    ValveCount : INT; (* Number of valves actually used (1-8) *)
    Valve1DeviceId : INT; (* Reference to devices.Id for valve 1 *)
    Valve2DeviceId : INT; (* Reference to devices.Id for valve 2 *)
    Valve3DeviceId : INT; (* Reference to devices.Id for valve 3 *)
    Valve4DeviceId : INT; (* Reference to devices.Id for valve 4 *)
    Valve5DeviceId : INT; (* Reference to devices.Id for valve 5 *)
    Valve6DeviceId : INT; (* Reference to devices.Id for valve 6 *)
    Valve7DeviceId : INT; (* Reference to devices.Id for valve 7 *)
    Valve8DeviceId : INT; (* Reference to devices.Id for valve 8 *)
    Valve1FeedbackInUse : BOOL; (* Valve 1: TRUE=require position feedback before pump start *)
    Valve2FeedbackInUse : BOOL; (* Valve 2: TRUE=require position feedback before pump start *)
    Valve3FeedbackInUse : BOOL; (* Valve 3: TRUE=require position feedback before pump start *)
    Valve4FeedbackInUse : BOOL; (* Valve 4: TRUE=require position feedback before pump start *)
    Valve5FeedbackInUse : BOOL; (* Valve 5: TRUE=require position feedback before pump start *)
    Valve6FeedbackInUse : BOOL; (* Valve 6: TRUE=require position feedback before pump start *)
    Valve7FeedbackInUse : BOOL; (* Valve 7: TRUE=require position feedback before pump start *)
    Valve8FeedbackInUse : BOOL; (* Valve 8: TRUE=require position feedback before pump start *)
    PumpDeviceId : INT; (* Reference to devices.Id for the pump *)
    ValveFeedbackTimeout : INT; (* Seconds to wait for valve position confirmation *)
    RecipeCount : INT; (* Number of recipes configured (1-8) *)
END_STRUCT
END_TYPE
