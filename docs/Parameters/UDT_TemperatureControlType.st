(* TemperatureControlType - Data structure derived from param.temperature_control SQL tables *)
(* ControlType: 0=Heating, 1=Cooling, 2=Heating/Cooling *)
(* ControlMode: 0=Rest, 1=Work *)
(* SensorSelectionMode: 0=T1 only, 1=T2 only, 2=T1 master/T2 slave, 3=T2 master/T1 slave, 4=Average *)
TYPE UDT_TemperatureControlType :
STRUCT
    TemperatureId : INT; (* Primary key *)
    TankId : INT; (* Reference to tanks.TankId *)
    IsInUse : BOOL; (* Control enabled *)
    ControlType : INT; (* 0=Heating, 1=Cooling, 2=Both *)
    ControlMode : INT; (* Control mode 0=Rest, 1=Work *)
    SetValueProd : REAL; (* Setpoint - production mode *)
    SetValueIdle : REAL; (* Setpoint - idle mode *)
    Tolerance : REAL; (* Control tolerance/deadband *)
    PreconditioningTolerance : REAL; (* Additional tolerance during preconditioning *)
    MinAlarmProd : REAL; (* Min alarm limit - production *)
    MaxAlarmProd : REAL; (* Max alarm limit - production *)
    MinAlarmIdle : REAL; (* Min alarm limit - idle *)
    MaxAlarmIdle : REAL; (* Max alarm limit - idle *)
    AlarmDeadband : REAL; (* Alarm deadband value *)
    MeasurementId : INT; (* Reference to measurements - primary sensor T1 *)
    Measurement2Id : INT; (* Reference to measurements - secondary sensor T2, 0=not used *)
    SensorSelectionMode : INT; (* 0=T1 only, 1=T2 only, 2=T1 master/T2 slave, 3=T2 master/T1 slave, 4=Average *)
    SensorSwitchoverTolerance : REAL; (* Tolerance for master/slave switchover detection *)
    SensorDiscrepancyAlarm : REAL; (* Max allowed difference between T1 and T2 before alarm *)
    HeatingDeviceId : INT; (* Reference to devices.Id *)
    CoolingDeviceId : INT; (* Reference to devices.Id *)
    PreconditioningTime : INT; (* Preconditioning time s *)
END_STRUCT
END_TYPE
