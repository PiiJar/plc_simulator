(* ChargeEventType - Data structure derived from param.charge_events SQL tables - Production event tracking *)
TYPE UDT_ChargeEventType :
STRUCT
    EventId : INT; (* Primary key *)
    ChargeId : STRING(30); (* Reference to charge *)
    LiftStationId : INT; (* Lift station *)
    SinkStationId : INT; (* Sink station *)
    TransporterId : INT; (* Transporter used *)
    LiftTimeUnix : DINT; (* Lift time Unix timestamp *)
    TreatmentTimeMin : INT; (* Min treatment time s *)
    TreatmentTimeMax : INT; (* Max treatment time s *)
    ActualTreatmentDuration : INT; (* Actual duration s *)
    TemperatureMin : REAL; (* Min temperature *)
    TemperatureMax : REAL; (* Max temperature *)
    TemperatureSet : REAL; (* Setpoint temperature *)
    TemperatureAvg : REAL; (* Average temperature *)
    ConductivityMin : REAL; (* Min conductivity *)
    ConductivityMax : REAL; (* Max conductivity *)
    ConductivitySet : REAL; (* Setpoint conductivity *)
    ConductivityAvg : REAL; (* Average conductivity *)
    PHMin : REAL; (* Min pH *)
    PHMax : REAL; (* Max pH *)
    PHSet : REAL; (* Setpoint pH *)
    PHAvg : REAL; (* Average pH *)
    CurrentAh : REAL; (* Ampere-hours *)
    CurrentMax : REAL; (* Max current *)
    CurrentAvg : REAL; (* Average current *)
    VoltageMax : REAL; (* Max voltage *)
    VoltageAvg : REAL; (* Average voltage *)
    Kwh : REAL; (* Energy consumption *)
END_STRUCT
END_TYPE
